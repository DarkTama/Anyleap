{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main + controls windows",
  "windows": ["main", "controls"],
  "permissions": [
    "core:default",
    "store:default",
    "core:webview:allow-create-webview-window",
    "core:window:allow-start-dragging",
    "core:window:allow-close",
    "core:window:allow-set-focus",
    "core:window:allow-set-position",
    "core:window:allow-outer-size",
    "core:window:allow-hide",
    "core:window:allow-show",
    {
      "identifier": "shell:allow-spawn",
      "allow": [{ "name": "binaries/scrcpy", "sidecar": true, "args": true }]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "binaries/adb", "sidecar": true, "args": true },
        { "name": "binaries/scrcpy", "sidecar": true, "args": true }
      ]
    }
  ]
}
