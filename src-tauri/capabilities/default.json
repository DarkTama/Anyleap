{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "store:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [{ "name": "binaries/scrcpy", "sidecar": true, "args": true }]
    },
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "binaries/adb", "sidecar": true, "args": true },
        { "name": "binaries/scrcpy", "sidecar": true, "args": true }
      ]
    }
  ]
}
